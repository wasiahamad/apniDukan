# Example environment file (DO NOT put secrets in git)

# Server
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=

# Auth
JWT_SECRET=
JWT_EXPIRE=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay
# Use rzp_test_* in dev, rzp_live_* in production
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Frontend
FRONTEND_URL=http://localhost:8080
PLATFORM_NAME=ApniDukan

# Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Email/SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
