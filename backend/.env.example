# Core
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/apnidukan

# Mongo Atlas / DNS tuning (optional)
# If you're using mongodb+srv:// and SRV DNS lookups are flaky on VPN/corporate networks,
# set custom resolvers (comma-separated). The code will fall back to public resolvers if SRV fails.
MONGO_DNS_SERVERS=
# SRV DNS lookup timeout in ms (prevents startup hangs). Default: 2500
MONGO_DNS_TIMEOUT_MS=2500
# Mongo driver timeouts (ms). Defaults: 20000/20000/45000
MONGO_SERVER_SELECTION_TIMEOUT_MS=20000
MONGO_CONNECT_TIMEOUT_MS=20000
MONGO_SOCKET_TIMEOUT_MS=45000

# JWT
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_chars

# CORS / Client
# Comma-separated list of allowed frontend origins.
# Examples:
# CLIENT_URL=http://localhost:8080,http://localhost:8081
# CLIENT_URL=https://publicdukan.com,https://seller.publicdukan.com
CLIENT_URL=http://localhost:5173
# Render or other production frontends can be added here, for example:
# CLIENT_URL=https://your-frontend.onrender.com

# Optional: additional allowed origins (comma-separated)
# Useful when you have multiple deployments (Cloudflare Pages, Vercel previews, etc.)
# Render service URLs can also be added here if you use separate dashboard/admin apps.
CORS_ORIGINS=

# ----------------------------------------
# AI Agent System (Cloudflare Workers AI)
# ----------------------------------------
# For Node/Express backend, we call Cloudflare Workers AI via HTTP API.

# Daily AI request limits (IST day).
# Public chat is enforced per x-session-id/IP.
AI_LIMIT_PUBLIC=5
AI_LIMIT_OWNER_FREE=5

AI_LIMIT_OWNER_PREMIUM=50

# Optional: email notifications (Resend)
RESEND_API_KEY=
EMAIL_FROM=PublicDukan <noreply@publicdukan.com>
ADMIN_SUPPORT_EMAIL=support@publicdukan.com

# ----------------------------------------
# Public Storefront + SEO (Optional)
# ----------------------------------------
# If enabled, backend will serve the built `publicWebsite/dist` and inject SEO tags per host/subdomain.
# Useful when you want server-side injected meta tags for crawlers and rich previews.
SERVE_PUBLIC_WEBSITE=false

# Where the built Vite site lives (default: ../publicWebsite/dist)
PUBLIC_WEBSITE_DIST_DIR=

# Used to infer the root domain if PUBLIC_DUKAN_ROOT_DOMAIN not set.
# Example: https://publicdukan.com
PUBLIC_WEBSITE_URL=

# Root domain for subdomain storefronts (default: publicdukan.com)
PUBLIC_DUKAN_ROOT_DOMAIN=publicdukan.com

# Comma-separated reserved subdomains that should NOT be treated as storefronts.
# Defaults: www,seller,api,admin
PUBLIC_DUKAN_RESERVED_SUBDOMAINS=

# Bot SSR-lite HTML snapshot (used only when SERVE_PUBLIC_WEBSITE=true)
ENABLE_STORE_FRONT_BOT_SSR=true

# SEO cache TTL for robots/sitemap generation (seconds). Default: 300
SEO_CACHE_TTL_SECONDS=300

# IndexNow (Bing + partners) optional
INDEXNOW_KEY=
# Optional URL where the key is hosted; defaults to https://<host>/<key>.txt
INDEXNOW_KEY_LOCATION=

# Google Search Console verification (File method)
# This serves a verification HTML at /<fileName> with the provided content.
GOOGLE_SITE_VERIFICATION_FILE_NAME=
GOOGLE_SITE_VERIFICATION_FILE_CONTENT=

# Default image for /share/order-summary preview (optional)
SHARE_DEFAULT_IMAGE_URL=
