# Core
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/apnidukan

# Mongo Atlas / DNS tuning (optional)
# If you're using mongodb+srv:// and SRV DNS lookups are flaky on VPN/corporate networks,
# set custom resolvers (comma-separated). The code will fall back to public resolvers if SRV fails.
MONGO_DNS_SERVERS=
# SRV DNS lookup timeout in ms (prevents startup hangs). Default: 2500
MONGO_DNS_TIMEOUT_MS=2500
# Mongo driver timeouts (ms). Defaults: 20000/20000/45000
MONGO_SERVER_SELECTION_TIMEOUT_MS=20000
MONGO_CONNECT_TIMEOUT_MS=20000
MONGO_SOCKET_TIMEOUT_MS=45000

# JWT
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_chars

# CORS / Client
CLIENT_URL=http://localhost:5173

# ----------------------------------------
# AI Agent System (Cloudflare Workers AI)
# ----------------------------------------
# For Node/Express backend, we call Cloudflare Workers AI via HTTP API.

# Daily AI request limits (IST day).
# Public chat is enforced per x-session-id/IP.
AI_LIMIT_PUBLIC=5
AI_LIMIT_OWNER_FREE=5

AI_LIMIT_OWNER_PREMIUM=50

# Optional: email notifications for important insights
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
