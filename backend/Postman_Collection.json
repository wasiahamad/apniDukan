				{
					"name": "Register User ðŸ”“",
					"event": [{
						"listen": "test",
						"script": {
							"exec": [
								"if (pm.response.code === 201) {",
								"    const r = pm.response.json();",
								"    pm.collectionVariables.set('accessToken', r.data.accessToken);",
								"    pm.collectionVariables.set('refreshToken', r.data.refreshToken);",
								"    pm.collectionVariables.set('userId', r.data.user._id);",
								"}"
							],
							"type": "text/javascript"
						}
					}],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Test Owner\",\n  \"email\": \"owner@example.com\",\n  \"phone\": \"9000000001\",\n  \"password\": \"password123\"\n}"
						},
						"url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] }
					},
					"response": []
				},
