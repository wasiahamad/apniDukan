{
  "name": "apnidukan-backend",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS platform backend - Universal business management system",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seed.js",
    "seed:dev": "NODE_ENV=development node scripts/seed.js",
    "seed:prod": "NODE_ENV=production node scripts/seed.js",
    "backfill:categories": "node scripts/backfillDefaultCategories.js",
    "fix:indexes:categories": "node scripts/fix-category-indexes.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop apnidukan-backend",
    "pm2:restart": "pm2 restart apnidukan-backend",
    "pm2:logs": "pm2 logs apnidukan-backend",
    "pm2:monit": "pm2 monit",
    "pm2:delete": "pm2 delete apnidukan-backend",
    "logs": "tail -f logs/combined.log",
    "logs:error": "tail -f logs/error.log"
  },
  "keywords": [
    "multi-tenant",
    "saas",
    "mern",
    "mongodb",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.17.1",
    "razorpay": "^2.9.6",
    "slugify": "^1.6.6",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
